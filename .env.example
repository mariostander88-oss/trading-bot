ALPACA_API_KEY=your_paper_api_key_here
ALPACA_SECRET_KEY=your_paper_secret_key_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

TRADING_MODE=paper
LIVE_TRADING_CONFIRMED=false

WATCHLIST=SPY,QQQ,NVDA,AMD,AVGO,TSM,ASML,MSFT,GOOGL,AMZN,META,ORCL,PLTR,SMCI,ARM,TSLA
TIMEFRAME_MINUTES=15
HISTORICAL_BARS_LIMIT=120
DATA_FEED=iex

MAX_RISK_PER_TRADE=0.01
MAX_DAILY_LOSS=0.03
DAILY_PROFIT_TARGET=0.01
DAILY_GOAL_BLOCKS_NEW_BUYS=true
MAX_OPEN_POSITIONS=3
STOP_LOSS_PCT=0.02

DATABASE_URL=
DATABASE_PATH=trading_bot.db

DASHBOARD_PASSWORD=
API_ADMIN_TOKEN=

NOTIFICATIONS_ENABLED=false
NOTIFICATION_CHANNELS=email
NOTIFICATION_TIMES=09:00,18:00
NOTIFICATION_TIMEZONE=Africa/Nairobi
REPORT_SUBJECT_PREFIX=Trading Bot

# Email reports use SMTP. For Gmail, use an app password instead of your normal password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# WhatsApp reports use Twilio WhatsApp. Values should look like whatsapp:+15551234567 or +15551234567.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
TWILIO_WHATSAPP_TO=
